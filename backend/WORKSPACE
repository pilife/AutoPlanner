workspace(name = "autoplanner")

load("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")

# cpp-httplib (header-only HTTP server)
http_archive(
    name = "cpp_httplib",
    urls = ["https://github.com/yhirose/cpp-httplib/archive/refs/tags/v0.18.3.tar.gz"],
    strip_prefix = "cpp-httplib-0.18.3",
    build_file_content = """
cc_library(
    name = "httplib",
    hdrs = ["httplib.h"],
    includes = ["."],
    visibility = ["//visibility:public"],
)
""",
)

# nlohmann/json (header-only JSON library)
http_archive(
    name = "nlohmann_json",
    urls = ["https://github.com/nlohmann/json/releases/download/v3.11.3/include.zip"],
    build_file_content = """
cc_library(
    name = "json",
    hdrs = glob(["include/**/*.hpp"]),
    includes = ["include"],
    visibility = ["//visibility:public"],
)
""",
)

# SQLite3 amalgamation
http_archive(
    name = "sqlite3",
    urls = ["https://www.sqlite.org/2024/sqlite-amalgamation-3450000.zip"],
    strip_prefix = "sqlite-amalgamation-3450000",
    build_file_content = """
cc_library(
    name = "sqlite3",
    srcs = ["sqlite3.c"],
    hdrs = ["sqlite3.h", "sqlite3ext.h"],
    includes = ["."],
    visibility = ["//visibility:public"],
)
""",
)
